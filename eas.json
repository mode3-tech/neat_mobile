{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_API_URL": "https://neat-mobile-backend-nhsk.onrender.com/api/v1"
      }
    },
    "preview": {
      "distribution": "store",
      "channel": "preview",
      "environment": "preview",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_URL": "https://neat-mobile-backend-nhsk.onrender.com/api/v1",
        "EXPO_PUBLIC_ANDROID_CERT_SHA256": "9siJv+kxI1/Sd5rlv8OBFEpKkIq1AHC9bPyqLgoDNWc="
        // "EXPO_PUBLIC_IOS_TEAM_ID": ""
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "production",
        "EXPO_PUBLIC_API_URL": "https://neat-mobile-backend-nhsk.onrender.com/api/v1"
        // "EXPO_PUBLIC_ANDROID_CERT_SHA256": "",
        // "EXPO_PUBLIC_IOS_TEAM_ID": ""
      }
    }
  },
  "submit": {
    "production": {}
  }
}
